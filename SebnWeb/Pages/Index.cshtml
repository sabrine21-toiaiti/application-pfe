@page
@model SebnWeb.Pages.IndexModel
@{ ViewData["Title"] = "Connexion"; }

<div class="login-card text-center">
    <img src="~/images/logo_sebn.png" style="width:220px;" />
    <h4 class="mt-3" style="color:var(--navy-dark);">Système de Détection Automatique<br/>des Non-Conformités</h4>
    <p class="text-muted">SEBN El Fejja — Département PIT</p>

    <form method="post" class="text-start mt-4">
        @if (Model.Erreur != null)
        {
            <div class="alert alert-danger">@Model.Erreur</div>
        }
        <div class="mb-3">
            <label class="form-label">Identifiant</label>
            <input class="form-control" asp-for="Login" />
        </div>
        <div class="mb-3">
            <label class="form-label">Mot de passe</label>
            <input class="form-control" type="password" asp-for="MotDePasse" />
        </div>
        <button type="submit" class="btn btn-sebn w-100">Se connecter</button>
    </form>

    <details class="mt-4 text-start">
        <summary class="text-muted" style="cursor:pointer;">🔑 Comptes de démonstration</summary>
        <table class="table table-sm mt-2">
            <thead><tr><th>Rôle</th><th>Login</th><th>Mot de passe</th></tr></thead>
            <tbody>
                <tr><td>Superviseur Production</td><td><code>superviseur</code></td><td><code>sebn2026</code></td></tr>
                <tr><td>Auditeur Qualité</td><td><code>qualite</code></td><td><code>sebn2026</code></td></tr>
                <tr><td>Administrateur PIT</td><td><code>admin</code></td><td><code>sebn2026</code></td></tr>
                <tr><td>Direction Générale</td><td><code>direction</code></td><td><code>sebn2026</code></td></tr>
            </tbody>
        </table>
    </details>
</div>
