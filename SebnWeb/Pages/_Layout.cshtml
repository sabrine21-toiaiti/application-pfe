@{
    var nomAffichage = Context.Session.GetString("NomAffichage");
    var role = Context.Session.GetString("Role");
    var page = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] | SEBN</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
@if (nomAffichage == null)
{
    @RenderBody()
}
else
{
    <div class="d-flex">
        <nav class="sebn-sidebar" style="width:240px;">
            <img src="~/images/logo_sebn.png" style="width:150px; margin-bottom:20px;" />
            <div class="mb-1 fw-bold">@nomAffichage</div>
            <div class="mb-4" style="font-size:13px; opacity:0.75;">@role</div>

            <a href="/Dashboard" class="@(page=="/Dashboard"?"active":"")">📊 Dashboard</a>
            <a href="/FluxVideo" class="@(page=="/FluxVideo"?"active":"")">📹 Flux vidéo</a>
            <a href="/Historique" class="@(page=="/Historique"?"active":"")">🕓 Historique</a>
            @if (role == "Administrateur PIT")
            {
                <a href="/Administration" class="@(page=="/Administration"?"active":"")">⚙️ Administration</a>
            }
            <hr style="border-color: rgba(255,255,255,0.2);" />
            <form method="post" action="/Index?handler=Logout">
                <button type="submit" class="btn btn-sm btn-outline-light w-100">Se déconnecter</button>
            </form>
        </nav>
        <main class="flex-grow-1 p-4">
            @RenderBody()
        </main>
    </div>
}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
